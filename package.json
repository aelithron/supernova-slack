      "onFail": "download"
    }
  },
  "type": "module",
  "dependencies": {
    "@slack/bolt": "^4.7.3",
    "@slack/web-api": "^7.18.0",
    "amazon-chime-sdk-js": "^3.31.0",
    "dotenv": "^17.4.2",
    "wrtc": "^0.4.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.0",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "jiti": "^2.7.0",
    "nodemon": "^3.1.14",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1"
  }
}