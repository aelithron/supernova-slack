{
  "name": "supernova-slack",
  "version": "1.0.0",
  "description": "A personal selfbot for Slack!",
  "main": "index.js",
  "scripts": {
    "dev": "nodemon -w package.json -w src -x 'tsx' --delay 2.5s ./src/index.ts",
    "lint": "eslint",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "slack",
    "selfbot"
  ],
  "author": "Nova",
  "license": "MIT",
  "devEngines": {
