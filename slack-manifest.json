{
    "display_information": {
        "name": "supernovaaaa",
        "description": "helper bot for @supernova, made by nova!",
        "background_color": "#e330bc",
        "long_description": "hi! i'm a helper bot for the things that @supernova can't do on her own! this is mainly slash commands and modals :3\r\n\r\nsource code: https://github.com/aelithron/supernova-slack"
    },
    "features": {
        "app_home": {
            "home_tab_enabled": false,
            "messages_tab_enabled": true,
            "messages_tab_read_only_enabled": true
        },
        "bot_user": {
            "display_name": "supernovaaaa",
            "always_online": false
        },
        "slash_commands": [
            {
                "command": "/huddles",
                "description": "controls huddles for @supernova",
                "usage_hint": "<join|leave> [channel]",
                "should_escape": true
            }
        ]
    },
    "oauth_config": {
        "scopes": {
            "user": [
                "channels:history",
                "chat:write",
                "groups:history",
                "im:history",
                "mpim:history"
            ],
            "bot": [
                "app_mentions:read",
                "channels:history",
                "chat:write",
                "chat:write.public",
                "commands",
                "groups:history"
            ]
        },
        "pkce_enabled": false
    },
    "settings": {
        "event_subscriptions": {
            "user_events": [
                "message.channels",
                "message.groups",
                "message.im",
                "message.mpim"
            ],
            "bot_events": [
                "app_mention",
                "message.channels",
                "message.groups"
            ]
        },
        "interactivity": {
            "is_enabled": true
        },
        "org_deploy_enabled": false,
        "socket_mode_enabled": true,
        "token_rotation_enabled": false,
        "is_mcp_enabled": false
    }
}